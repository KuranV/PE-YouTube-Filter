{
  "manifest_version": 3,
  "name": "PE YouTube Filter",
  "version": "1.2.2",
  "description": "Detect and filter YouTube channels owned or managed by private equity firms and talent management companies.",
  "browser_specific_settings": {
    "gecko": {
      "id": "pe-youtube-filter@kuranv.github.io",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://raw.githubusercontent.com/*",
    "*://*.workers.dev/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "PE YouTube Filter",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["report.html"],
      "matches": ["*://*.youtube.com/*"]
    }
  ]
}
